// Prisma Schema - Gonglijeongli Web
// Docs: https://pris.ly/d/prisma-schema
//
// 이 파일은 DB 테이블 구조를 정의합니다.
// 수정 후 `npx prisma migrate dev --name <설명>` 으로 마이그레이션 생성.
// Prisma Client는 `npx prisma generate` 로 재생성됩니다.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── 행사(Event) 모델 ───
// swagger.yaml의 EventItem 스키마와 1:1 대응
model Event {
  id        Int      @id @default(autoincrement()) // 자동 증가 PK
  title     String // 행사명
  date      String // "2026.03.15" 또는 "2026.03.15 ~ 2026.03.16"
  location  String // 행사 장소
  thumb     String? // 썸네일 이미지 경로 (선택)
  link      String? // 외부 링크 (선택)
  status    String   @default("upcoming") // "upcoming" | "ongoing" | "ended"
  createdAt DateTime @default(now()) // 생성 시각
  updatedAt DateTime @updatedAt // 수정 시각

  @@map("events") // 실제 DB 테이블 이름을 "events"로 지정
}

// ─── 공지사항/소식(News) 모델 ───
model News {
  id        Int      @id @default(autoincrement()) // 자동 증가 PK
  title     String // 뉴스/공지사항 제목
  content   String // 본문 내용 (Tiptap JSON의 문자열 형태 등)
  thumbnail String? // 썸네일 이미지 경로 (선택)
  date      String // 작성일 표기 (예: "2026.02.10")
  views     Int      @default(0) // 조회수
  likes     Int      @default(0) // 좋아요 수
  createdAt DateTime @default(now()) // 데이터 생성 시각
  updatedAt DateTime @updatedAt // 데이터 수정 시각

  @@map("news") // 실제 DB 테이블 이름을 "news"로 지정
}

// ─── 작품(Work) 모델 ───
model Work {
  id          Int      @id @default(autoincrement()) // 자동 증가 PK
  title       String // 작품명
  description String? // 설명 (선택)
  date        String // 발행일 (예: "2026.02")
  thumb       String? // 썸네일 이미지 경로 (선택)
  link        String? // 외부 링크 (선택)
  tags        String // 태그 목록 (JSON 배열 문자열로 저장)
  createdAt   DateTime @default(now()) // 데이터 생성 시각
  updatedAt   DateTime @updatedAt // 데이터 수정 시각

  @@map("works") // 실제 DB 테이블 이름을 "works"로 지정
}

// ─── 이미지 관리 모델 ───
// 시스템에 직접 업로드된 파일 정보. hash로 중복 방지.
model Image {
  id        String   @id @default(uuid())
  hash      String   @unique // 파일의 SHA-256 해시값 (중복 방지용)
  url       String   @unique // 파일 접근 URL (/uploads/xyz.jpg)
  createdAt DateTime @default(now()) // 최초 업로드 시간

  references ImageReference[]

  @@map("images")
}

// 특정 이미지(Image)가 어느 엔티티(News, Work 등)에 사용중인지 기록
model ImageReference {
  id         String @id @default(uuid())
  imageId    String
  image      Image  @relation(fields: [imageId], references: [id], onDelete: Cascade)
  targetType String // 참조하는 주체 타입 ("news", "works", "events")
  targetId   Int // 참조하는 주체의 ID (예: news.id)

  @@index([targetType, targetId]) // 특정 주체의 이미지들을 빠르게 지울 때 유용한 인덱스
  @@map("image_references")
}

// ─── 홈 배너(Banner) 모델 ───
model Banner {
  id           Int      @id @default(autoincrement())
  imageUrl     String   // 업로드된 이미지 경로
  linkUrl      String?  // 클릭 시 이동할 URL (선택 사항)
  displayOrder Int      @default(0) // 배너 노출 순서
  isActive     Boolean  @default(true) // 메인 페이지 노출 여부
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("banners")
}


model SiteConfig {
  id             Int     @id @default(1)
  
  // 탭 표시 여부
  showAboutTab   Boolean @default(true)
  showNewsTab    Boolean @default(true)
  showEventsTab  Boolean @default(true)
  showWorksTab   Boolean @default(true)
  showGalleryTab Boolean @default(true)

  // 홈 화면 박스 표시 여부
  showAboutBox   Boolean @default(true)
  showNewsBox    Boolean @default(true)
  showEventsBox  Boolean @default(true)
  showWorksBox   Boolean @default(true)
  showGalleryBox Boolean @default(true)

}
