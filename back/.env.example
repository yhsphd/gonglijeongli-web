# 서버 설정
PORT=3000
NODE_ENV=development

# CORS 설정 (Production)
# 쉼표(,)로 구분된 허용할 origin 목록 (프로토콜 포함 전체 URL)
CORS_ALLOWED_ORIGINS="https://toho.example.com"
# 허용할 메인 도메인 (모든 서브도메인 포함 허용: *.example.com)
CORS_ALLOWED_DOMAIN="example.com"

# 세션 쿠키 서명용 비밀키 (랜덤 문자열 권장)
SESSION_SECRET=your-secret-key-here

# 관리자 계정
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# 데이터베이스 (Prisma)
DATABASE_URL="file:./dev.db"
