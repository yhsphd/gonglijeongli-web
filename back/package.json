  "main": "index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts",
    "db:start": "prisma migrate deploy && node dist/index.js",
    "deploy": "prisma migrate deploy",
    "build": "prisma generate && tsc && node -e \"require('fs').cpSync('swagger.yaml','dist/swagger.yaml')\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint .",
    "lint:eslint": "eslint . --cache",
    "format": "prettier --check --experimental-cli src/",
    "fix": "run-s fix:*",
    "fix:oxlint": "oxlint . --fix",
    "fix:eslint": "eslint . --fix --cache",
    "fix:format": "prettier --write --experimental-cli src/",
    "clean": "rimraf dist src/generated",
    "postinstall": "prisma generate",
    "reset": "npm run clean && npm run postinstall"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
