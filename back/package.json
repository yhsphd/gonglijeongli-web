    "eslint-plugin-oxlint": "^1.49.0",
    "jiti": "^2.6.1",
    "nodemon": "^3.1.14",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.49.0",
    "prettier": "^3.8.1",
    "prisma": "^7.4.2",
